{
  "version": 2,
  "public": true,
  "functions": {
    "src/index.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/src/index.js"
    },
    {
      "src": "/docs",
      "dest": "/src/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/page/$1"
    }
  ]
}
